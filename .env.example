# === Required ===
LLM_BASE_URL=http://127.0.0.1:1234/v1
QDRANT_URL=http://localhost:6333
MODEL=local-model

# How many chat sessions between full observer synthesis (default: 3)
SYNTHESIS_INTERVAL=3

# === Discord bot (optional) ===
# Only needed if running the Discord bot with `npm run discord`
DISCORD_TOKEN=your-discord-bot-token
CHANNEL_ID=your-discord-channel-id
SPECS_CHANNEL_ID=your-specs-channel-id
GUILD_ID=your-discord-guild-id
BOT_NAME=cecil

# === Discord multi-agent meetings (optional) ===
# Only needed if running meeting facilitation mode
# DISCORD_AGENTS={"agent1":"bot-id-1","agent2":"bot-id-2"}
# MEETING_AGENT_ORDER=agent1,agent2,agent3
# SPEC_AGENT=agent1
# BUILD_AGENT=agent2
