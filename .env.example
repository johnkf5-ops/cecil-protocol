ANTHROPIC_API_KEY=your-api-key-here
QDRANT_URL=http://localhost:6333
MODEL=claude-sonnet-4-6
SYNTHESIS_INTERVAL=3

# Discord bot (optional — only needed if running the Discord bot)
DISCORD_TOKEN=your-discord-bot-token
CHANNEL_ID=your-discord-channel-id
SPECS_CHANNEL_ID=your-specs-channel-id
GUILD_ID=your-discord-guild-id
BOT_NAME=cecil

# Discord agent configuration (optional — only needed for meeting mode)
# DISCORD_AGENTS: JSON mapping of agent names to Discord bot IDs
# DISCORD_AGENTS={"agent1":"bot-id-1","agent2":"bot-id-2"}
# MEETING_AGENT_ORDER: comma-separated agent names for meeting rotation order
# MEETING_AGENT_ORDER=agent1,agent2,agent3
# SPEC_AGENT: agent name that receives !approve handoff
# SPEC_AGENT=agent1
# BUILD_AGENT: agent name tagged after spec is written
# BUILD_AGENT=agent2
