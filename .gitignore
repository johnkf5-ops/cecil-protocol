# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
._*
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local

# qdrant local storage
/qdrant_storage

# fastembed model cache
/local_cache

# personal runtime data (not part of the protocol)
/identity/seed.md
/identity/narrative.md
/identity/delta.md
/identity/profile.md
/memory/conversations/
/memory/observations/
/memory/podcasts/
/memory/milestones/
/memory/.session-counter.json
/podcasts/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
